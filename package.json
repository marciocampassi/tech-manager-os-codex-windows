{
  "name": "@marlonvidal/tech-manager-os",
  "version": "1.0.0",
  "description": "AI-powered CLI for engineering managers — process meeting notes, manage your team, track your career.",
  "type": "module",
  "bin": {
    "tmr": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "ts-node src/cli.ts",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "prepare": "[ -d .git ] && husky || true",
    "typecheck": "tsc --noEmit",
    "validate": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "cli",
    "engineering-manager",
    "ai",
    "productivity"
  ],
  "author": "Marlon Vidal",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.3.0",
    "@types/which": "^3.0.4",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/generative-ai": "^0.24.1",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "date-fns": "^3.6.0",
    "dotenv": "^17.3.1",
    "fs-extra": "^11.3.3",
    "googleapis": "^144.0.0",
    "gray-matter": "^4.0.3",
    "inquirer": "^13.3.0",
    "openai": "^6.25.0",
    "ora": "^9.3.0",
    "which": "^5.0.0",
    "winston": "^3.19.0"
  }
}
